# Файл .gitignore
# Игнорируем изображения (они могут быть большими)
/images/*.jpg
/images/*.jpeg
/images/*.png
/images/*.gif

# Игнорируем временные файлы
*.tmp
*.log
*.cache

# Игнорируем файлы конфигурации IDE
.vscode/
.idea/
*.swo
*.swp

# Игнорируем файлы с паролями (если такие есть)
php/config.local.php
